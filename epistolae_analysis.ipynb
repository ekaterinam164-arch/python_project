    {
      "cell_type": "code",
      "source": [
        "def avg_sentence_length(letters):\n",
        "    per_letter_means = []\n",
        "\n",
        "    for text in letters:\n",
        "        doc = nlp(text)\n",
        "        lengths = [\n",
        "            sum(1 for word in sent.words if word.upos != 'PUNCT')\n",
        "            for sent in doc.sentences\n",
        "        ]\n",
        "        lengths = [l for l in lengths if l > 0]\n",
        "        if lengths:\n",
        "            per_letter_means.append(sum(lengths) / len(lengths))\n",
        "\n",
        "    return per_letter_means"
      ],
      "metadata": {
        "id": "htFbmhxjE6ez"
      },
      "execution_count": 74,
      "outputs": []
