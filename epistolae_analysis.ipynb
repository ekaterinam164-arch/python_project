      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.cluster import DBSCAN\n",
        "from sklearn.neighbors import NearestNeighbors"
      ],
      "metadata": {
        "id": "b71FVrTzp7-4"
      },
      "execution_count": 52,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "db = DBSCAN(eps=0.8, min_samples=2, metric='cosine') # параметры я установила скорее наугад, чтобы было как можно меньше выбросов, но и кластеры выглядели адекватно\n",
        "db.fit(X_corpus)\n",
        "labels = db.labels_"
      ],
      "metadata": {
        "id": "Wrmm1UWLq4PF"
      },
      "execution_count": 124,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "print(f\"Кластеров: {len(set(labels)) - (1 if -1 in labels else 0)}\")\n",
        "print(f\"Выбросов: {sum(labels == -1)}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "BwK3Q7TnrBj9",
        "outputId": "b2431141-b4f7-439a-a3c8-aec270b7e3bb"
