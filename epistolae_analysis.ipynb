      "source": [
        "m_top_words = []\n",
        "m_top_scores = []\n",
        "\n",
        "for chapter_idx in range(len(m_letters_nouns)):\n",
        "    sorted_chapter = sorted(\n",
        "        zip(tfidf_m_vectorizer_nouns.get_feature_names_out(), text_m_vector_nouns.iloc[chapter_idx]),\n",
        "        key=lambda x: x[1],\n",
        "        reverse=True\n",
        "    )\n",
        "\n",
        "    top_5_reversed = sorted_chapter[:5][::-1] #топ-5\n",
        "    words = [w[0] for w in top_5_reversed]\n",
        "    scores = [w[1] for w in top_5_reversed]\n",
        "\n",
        "    m_top_words.append(words)\n",
        "    m_top_scores.append(scores)\n",
        "\n",
        "fig, axes = plt.subplots(nrows=2, ncols=3, figsize=(16, 9), sharex=True)\n",
        "fig.suptitle('Топ-5 ключевых слов в письмах Феодору Метохиту (tf-idf)', fontsize=16)\n",
        "\n",
        "for i, ax in enumerate(axes.flat):\n",
        "    if i >= len(m_letters_nouns):\n",
        "        ax.axis('off')\n",
        "        continue\n",
        "\n",
        "    ax.barh(m_top_words[i], m_top_scores[i], color='tomato')\n",
        "    ax.set_title(f'Письмо {m_indices[i]}', fontsize=11)\n",
        "    ax.set_xlim(0, max(max(scores) for scores in m_top_scores) * 1.1)\n",
        "\n",
        "    for j, v in enumerate(m_top_scores[i]):\n",
        "        ax.text(v + 0.005, j, f'{v:.3f}', va='center', fontsize=9)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
