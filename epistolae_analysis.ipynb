    {
      "cell_type": "code",
      "source": [
        "def function_word_ratio(letters):\n",
        "    FUNCTION_UPOS = {'ADP', 'CCONJ', 'SCONJ', 'DET', 'PRON', 'PART', 'AUX'}\n",
        "\n",
        "    per_letter_ratios = []\n",
        "\n",
        "    for text in letters:\n",
        "        doc = nlp(text)\n",
        "        func_count = 0\n",
        "        total_count = 0\n",
        "\n",
        "        for sent in doc.sentences:\n",
        "            for word in sent.words:\n",
        "                if word.upos in ('PUNCT', 'SYM'):\n",
        "                    continue\n",
        "                total_count += 1\n",
        "                if word.upos in FUNCTION_UPOS:\n",
        "                    func_count += 1\n",
        "\n",
        "        if total_count > 0:\n",
        "            per_letter_ratios.append(func_count / total_count)\n",
        "\n",
        "    return sum(per_letter_ratios) / len(per_letter_ratios) if per_letter_ratios else 0"
      ],
      "metadata": {
        "id": "LKD_66PqHAgw"
      },
      "execution_count": 84,
      "outputs": []
