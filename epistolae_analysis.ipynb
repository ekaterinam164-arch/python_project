      "source": [
        "def nouns_list(new_list, letters_list) -> list:\n",
        "  for letter in letters_list:\n",
        "    doc = nlp(letter)\n",
        "    lemmatized_letter = [word.lemma for sent in doc.sentences for word in sent.words if word.upos == 'NOUN']\n",
        "    letter_no_stop = ' '.join([token for token in lemmatized_letter if token not in stopswords_grc])\n",
        "    new_list.append(letter_no_stop)\n",
        "  return(new_list)"
      ],
      "metadata": {
        "id": "f4xTWljPDZwE"
