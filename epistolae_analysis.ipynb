3c4\\u1fc7 \\u03c4\\u03bf\\u1fe6 \\u03b8\\u03b5\\u03b9\\u03bf\\u03c4\\u03ac\\u03c4\\u03bf\\u03c5 \\u03b2\\u03b1\\u03c3\\u03b9\\u03bb\\u03ad\\u03c9\\u03c2 \\u03c3\\u03c0\\u03bf\\u03c5\\u03b4\\u1fc7 \\u03ba\\u03b1\\u1f76 \\u03c3\\u03c5\\u03bd\\u03ad\\u03c3\\u03b5\\u03b9, \\u03ba\\u03b1\\u1f76 \\u03c0\\u03c1\\u03cc\\u03c2 \\u03b3\\u03b5 \\u03c3\\u03bf\\u1fe6 \\u03c4\\u03bf\\u1fe6 \\u1f49\\u03bc\\u03b7\\u03c1\\u03b9\\u03ba\\u03bf\\u1fe6 \\u039d\\u03ad\\u03c3\\u03c4\\u03bf\\u03c1\\u03bf\\u03c2 \\u03b4\\u03b5\\u03be\\u03b9\\u03b1\\u1fd6\\u03c2 \\u03c6\\u03c1\\u03b1\\u03b4\\u03bc\\u03bf\\u03c3\\u03cd\\u03bd\\u03b1\\u03b9\\u03c2 \\u03ba\\u03b1\\u1f76 \\u03c3\\u03c5\\u03bd\\u03b4\\u03c1\\u03bf\\u03bc\\u03b1\\u1fd6\\u03c2. \\u1f41\\u03c0\\u03cc\\u03c3\\u03b1\\u03c2 \\u03bf\\u1f31\\u03bf\\u03bd\\u03b5\\u03af \\u03c4\\u03b9 \\u03c7\\u03c1\\u1ff6\\u03bc\\u03b1 \\u03c4\\u03b1\\u1fd6\\u03c2 \\u03c4\\u03bf\\u1fe6 \\u03b2\\u03b1\\u03c3\\u03b9\\u03bb\\u03ad\\u03c9\\u03c2 \\u1f10\\u03c0\\u03b9\\u03c6\\u03ad\\u03c1\\u03b5\\u03b9\\u03c2 \\u03c0\\u03c1\\u03ac\\u03be\\u03b5\\u03c3\\u03b9\\u03bd \\u03b1\\u1f50\\u03c4\\u03cc\\u03c2. \\u03a3\\u03c5\\u03bc\\u03c6\\u03b9\\u03bb\\u03bf\\u03c4\\u03b9\\u03bc\\u03bf\\u03cd\\u03bc\\u03b5\\u03bd\\u03bf\\u03c2 \\u03b3\\u1f70\\u03c1 \\u03c4\\u1ff7 \\u03b2\\u03b1\\u03c3\\u03b9\\u03bb\\u03b5\\u1fd6 \\u03c0\\u03b5\\u03c1\\u1f76 \\u03c4\\u1f70 \\u03b2\\u03b5\\u03bb\\u03c4\\u03af\\u03c9, \\u2018\\u03bd\\u03cd\\u03ba\\u03c4\\u03c9\\u03c1 \\u03ba\\u03b1\\u1f76 \\u03bc\\u03b5\\u03b8\\u2019 \\u1f21\\u03bc\\u03ad\\u03c1\\u03b1\\u03bd\\u2019 \\u03c0\\u03b5\\u03c1\\u1f76 \\u03c4\\u1f70 \\u03ba\\u03b1\\u03bb\\u1f70 \\u03c0\\u03cc\\u03b8\\u03bf\\u03bd \\u03ba\\u03b1\\u1f76 \\u03b6\\u1fc6\\u03bb\\u03bf\\u03bd \\u03b1\\u1f54\\u03be\\u03b5\\u03b9\\u03c2 \\u03b1\\u1f50\\u03c4\\u03bf\\u1fe6, \\u03ba\\u03b1\\u03b8\\u03ac\\u03c0\\u03b5\\u03c1 \\u1f29\\u03c1\\u03b1\\u03ba\\u03bb\\u03b5\\u1fd6 \\u03a4\\u03b5\\u03bb\\u03b1\\u03bc\\u1f7c\\u03bd \\u1f10\\u03c0\\u1f76 \\u03a4\\u03c1\\u03bf\\u03af\\u03b1\\u03c2 \\u03ba\\u03b1\\u1f76 \\u1f08\\u03bd\\u03c4\\u03af\\u03b3\\u03bf\\u03bd\\u03bf\\u03c2 \\u1f08\\u03bb\\u03b5\\u03be\\u03ac\\u03bd\\u03b4\\u03c1\\u1ff3 \\u03ba\\u03b1\\u1f76 \\u03a0\\u03ac\\u03c4\\u03c1\\u03bf\\u03ba\\u03bb\\u03bf\\u03c2 \\u1f08\\u03c7\\u03b9\\u03bb\\u03bb\\u03b5\\u1fd6. \\u1f45\\u03b8\\u03b5\\u03bd \\u03bf\\u1f50 \\u03b8\\u03ad\\u03c1\\u03bf\\u03c2 \\u03ba\\u03b1\\u1f76 \\u1f14\\u03b1\\u03c1 \\u03ba\\u03b1\\u03b9\\u03c1\\u03bf\\u1f7a\\u03c2 \\u1f61\\u03c1\\u03b9\\u03c3\\u03bc\\u03ad\\u03bd\\u03bf\\u03c5\\u03c2 \\u03b5\\u1f30\\u03c2 \\u1f45\\u03c0\\u03bb\\u03b1 \\u03ba\\u03b1\\u1f76 \\u03c0\\u03cc\\u03bd\\u03bf\\u03c5\\u03c2 \\u03c0\\u03b5\\u03c1\\u03b9\\u03bc\\u03ad\\u03bd\\u03b5\\u03c4\\u03b5, \\u1f00\\u03bb\\u03bb\\u1f70 \\u03c0\\u03ac\\u03bd\\u03c4\\u03c9\\u03bd \\u03ba\\u03b1\\u03b9\\u03c1\\u1ff6\\u03bd \\u03ba\\u03b1\\u1f76 \\u03c3\\u03c4\\u03bf\\u03b9\\u03c7\\u03b5\\u03af\\u03c9\\u03bd \\u03ba\\u03b1\\u03b9\\u03bd\\u03bf\\u03c4\\u03bf\\u03bc\\u03b5\\u1fd6\\u03c4\\u03b5 \\u03c4\\u1f70\\u03c2 \\u03c6\\u03cd\\u03c3\\u03b5\\u03b9\\u03c2. \\u03b8\\u03ad\\u03c1\\u03bf\\u03c2 \\u03b3\\u1f70\\u03c1 \\u03ba\\u03b1\\u1f76 \\u1f14\\u03b1\\u03c1 \\u03c4\\u03bf\\u1f7a\\u03c2 \\u03b2\\u03b1\\u03c1\\u03b5\\u1fd6\\u03c2 \\u03c0\\u03bf\\u03b9\\u03b5\\u1fd6\\u03c4\\u03b5 \\u03c7\\u03b5\\u03b9\\u03bc\\u1ff6\\u03bd\\u03b1\\u03c2 \\u03ba\\u03b1\\u1f76 \\u1f21\\u03bc\\u03ad\\u03c1\\u03b1\\u03c2 \\u03b1\\u1f56 \\u03c4\\u1f70 \\u03c4\\u1ff6\\u03bd \\u03bd\\u03c5\\u03ba\\u03c4\\u1ff6\\u03bd \\u03b2\\u03b1\\u03b8\\u03cd\\u03c4\\u03b1\\u03c4\\u03b1, \\u03ba\\u03b1\\u1f76 \\u1f00\\u03b3\\u03c1\\u03c5\\u03c0\\u03bd\\u03b5\\u1fd6\\u03c4\\u03b5 \\u03bc\\u03ad\\u03bd, \\u1f35\\u03bd\\u03b1 \\u03b1\\u1f31 \\u03c0\\u03cc\\u03bb\\u03b5\\u03b9\\u03c2 \\u1f00\\u03c6\\u03cc\\u03b2\\u03c9\\u03c2 \\u1f51\\u03c0\\u03bd\\u03ce\\u03c4\\u03c4\\u03c9\\u03c3\\u03b9\\u03bd, \\u03b1\\u1f34\\u03b8\\u03c1\\u03b9\\u03bf\\u03b9 \\u03b4\\u2019 \\u1f51\\u03c0\\u1f78 \\u03c7\\u03b9\\u03cc\\u03bd\\u03b9 \\u03ba\\u03b1\\u1f76 \\u03ba\\u03c1\\u03c5\\u03c3\\u03c4\\u03ac\\u03bb\\u03bb\\u1ff3 \\u03b4\\u03b9\\u03b1\\u03c4\\u03b5\\u03bb\\u03b5\\u1fd6\\u03c4\\u03b5, \\u1f35\\u03bd\\u2019 \\u1f21\\u03bc\\u03b5\\u1fd6\\u03c2 \\u1f00\\u03c3\\u03c6\\u03b1\\u03bb\\u1ff6\\u03c2 \\u1f10\\u03bd \\u03c4\\u03bf\\u1fd6\\u03c2 \\u03bf\\u1f34\\u03ba\\u03bf\\u03b9\\u03c2 \\u03bf\\u1f30\\u03ba\\u1ff6\\u03bc\\u03b5\\u03bd. \\u03c0\\u03ac\\u03bd\\u03c4\\u03b5\\u03c2 \\u03b3\\u1f70\\u03c1 \\u03c7\\u03b5\\u03b9\\u03bc\\u1ff6\\u03bd\\u03bf\\u03c2 \\u03ba\\u03c1\\u03cd\\u03c3\\u03c4\\u03b1\\u03bb\\u03bb\\u03bf\\u03b9 \\u03ba\\u03b1\\u1f76 \\u03c0\\u03ac\\u03bd\\u03c4\\u03b5\\u03c2 \\u03b8\\u03ad\\u03c1\\u03bf\\u03c5\\u03c2 \\u03ba\\u03b1\\u03cd\\u03c3\\u03c9\\u03bd\\u03b5\\u03c2 \\u03c4\\u1fc6\\u03c2 \\u1f51\\u03bc\\u03b5\\u03c4\\u03ad\\u03c1\\u03b1\\u03c2 \\u1f25\\u03c4\\u03c4\\u03bf\\u03c5\\u03c2 \\u03c6\\u03b1\\u03af\\u03bd\\u03bf\\u03bd\\u03c4\\u03b1\\u03b9 \\u03c3\\u03c0\\u03bf\\u03c5\\u03b4\\u1fc6\\u03c2 \\u03ba\\u03b1\\u1f76 \\u03b2\\u03b9\\u03b1\\u03b9\\u03cc\\u03c4\\u03b5\\u03c1\\u03bf\\u03bd \\u03bf\\u1f50\\u03b4\\u1f72\\u03bd \\u03c4\\u1ff6\\u03bd \\u1f01\\u03c0\\u03ac\\u03bd\\u03c4\\u03c9\\u03bd \\u1f64\\u03c6\\u03b8\\u03b7 \\u03c0\\u03bf\\u03c4\\u1f72 \\u03c4\\u1fc6\\u03c2 \\u1f51\\u03bc\\u1ff6\\u03bd \\u1f00\\u03c1\\u03b5\\u03c4\\u1fc6\\u03c2, \\u03bf\\u1f54\\u03b8\\u2019 \\u1f41\\u03c0\\u03cc\\u03c3\\u03b1 \\u03c4\\u03cd\\u03c7\\u03b1\\u03b9 \\u03c6\\u03ad\\u03c1\\u03bf\\u03c5\\u03c3\\u03b9\\u03bd \\u1f00\\u03bd\\u03ae\\u03bc\\u03b5\\u03c1\\u03bf\\u03b9 \\u03bf\\u1f54\\u03b8\\u2019 \\u1f41\\u03c0\\u03cc\\u03c3\\u03b1 \\u03c0\\u03bb\\u03b5\\u03af\\u03c3\\u03c4\\u03b7\\u03c2 \\u03b3\\u03ad\\u03bc\\u03bf\\u03c5\\u03c3\\u03b1\\u03b9 \\u03c4\\u1fc6\\u03c2 \\u1f00\\u03c9\\u03c1\\u03af\\u03b1\\u03c2 \\u1f67\\u03c1\\u03b1\\u03b9. \\u1f45\\u03b8\\u03b5\\u03bd \\u1f21 \\u03c0\\u03b5\\u03c1\\u1f76 \\u03c4\\u1f70 \\u03c4\\u03bf\\u03b9\\u03b1\\u1fe6\\u03c4\\u03b1 \\u03c6\\u03b9\\u03bb\\u03bf\\u03c4\\u03b9\\u03bc\\u03af\\u03b1 \\u1f10\\u03c6\\u03cc\\u03b4\\u03b9\\u03bf\\u03bd \\u03bc\\u03ad\\u03b3\\u03b1 \\u03c0\\u03c1\\u1f78\\u03c2 \\u03ba\\u03c4\\u1fc6\\u03c3\\u03b9\\u03bd \\u1f10\\u03c0\\u03b1\\u03af\\u03bd\\u03c9\\u03bd \\u03ba\\u03b1\\u03b8\\u03af\\u03c3\\u03c4\\u03b1\\u03c4\\u03b1\\u03b9 \\u03c0\\u03b1\\u03b3\\u03ba\\u03bf\\u03c3\\u03bc\\u03af\\u03c9\\u03bd. \\u03ba\\u03b1\\u1f76 \\u03bd\\u1fe6\\u03bd \\u1f51\\u03c6\\u2019 \\u1f21\\u03b4\\u03bf\\u03bd\\u1fc6\\u03c2 \\u03c3\\u03ba\\u03b9\\u03c1\\u03c4\\u1ff6\\u03c3\\u03b9 \\u03b4\\u03ae\\u03bc\\u03c9\\u03bd \\u03c0\\u03bb\\u03ae\\u03b8\\u03b7, \\u03c3\\u03ba\\u03b9\\u03c1\\u03c4\\u1ff6\\u03c3\\u03b9 \\u03c0\\u03cd\\u03bb\\u03b1\\u03b9 \\u03c0\\u03cc\\u03bb\\u03b5\\u03c9\\u03bd, \\u03c3\\u03ba\\u03b9\\u03c1\\u03c4\\u1ff6\\u03c3\\u03b9\\u03bd \\u03b1\\u1f31 \\u03c3\\u03b1\\u1f76 \\u03a3\\u03c4\\u03bf\\u03b1\\u1f76 \\u03ba\\u03b1\\u1f76 \\u1f08\\u03ba\\u03b1\\u03b4\\u03b7\\u03bc\\u03af\\u03b1\\u03b9 \\u03ba\\u03b1\\u1f76 \\u03bb\\u03cc\\u03b3\\u03bf\\u03b9 \\u03ba\\u03b1\\u1f76 \\u03c3\\u03b5\\u03bc\\u03bd\\u03bf\\u1f76 \\u039c\\u03bf\\u03c5\\u03c3\\u1ff6\\u03bd \\u03c7\\u03bf\\u03c1\\u03bf\\u03af, \\u03bf\\u1f53\\u03c2 \\u03b1\\u1f50\\u03c4\\u1f78\\u03c2 \\u03bd\\u03b5\\u03ba\\u03c1\\u03bf\\u03c5\\u03bc\\u03ad\\u03bd\\u03bf\\u03c5\\u03c2 \\u1f00\\u03bd\\u03ad\\u03c1\\u03c1\\u03c9\\u03c3\\u03b1\\u03c2, \\u03c8\\u03c5\\u03c7\\u1f74\\u03bd \\u1f10\\u03bd\\u03b8\\u03b5\\u1f76\\u03c2 \\u03ba\\u03b1\\u1f76 \\u03c0\\u03bd\\u03bf\\u1f74\\u03bd \\u03ba\\u03b1\\u03b9\\u03bd\\u03bf\\u03c4\\u03ad\\u03c1\\u03b1\\u03bd \\u03ba\\u03b1\\u03b8\\u03ac\\u03c0\\u03b5\\u03c1 \\u1f30\\u03b1\\u03c4\\u03c1\\u1f78\\u03c2 \\u03c0\\u03b1\\u03bd\\u03c4\\u1f78\\u03c2 \\u1f51\\u03c0\\u03ad\\u03c1\\u03c4\\u03b5\\u03c1\\u03bf\\u03c2 \\u1f08\\u03c3\\u03ba\\u03bb\\u03b7\\u03c0\\u03b9\\u03bf\\u1fe6.\",\n          \"\\u0395\\u1f30 \\u03bc\\u03b7\\u03b4\\u1f72\\u03bd \\u1f26\\u03bd \\u1f15\\u03c4\\u03b5\\u03c1\\u03bf\\u03bd \\u1f10\\u03bc\\u1f72 \\u03c0\\u03b5\\u03af\\u03b8\\u03b5\\u03b9\\u03bd \\u1f00\\u03c0\\u03bf\\u03c7\\u03c1\\u1ff6\\u03bd \\u1f04\\u03bb\\u03bb\\u03bf \\u03c4\\u03b9 \\u03c4\\u03bf\\u1f7a\\u03c2 \\u1f00\\u03bd\\u03b8\\u03c1\\u03ce\\u03c0\\u03bf\\u03c5\\u03c2 \\u1f22 \\u03ba\\u03b1\\u03c4\\u1f70 \\u03c4\\u1f78\\u03bd \\u03c6\\u03b1\\u03b9\\u03bd\\u03cc\\u03bc\\u03b5\\u03bd\\u03bf\\u03bd \\u1f21\\u03b3\\u03b5\\u1fd6\\u03c3\\u03b8\\u03b1\\u03b9 \\u03c4\\u03c1\\u03cc\\u03c0\\u03bf\\u03bd, \\u1f24\\u03c1\\u03ba\\u03b5\\u03b9\\u03c2 \\u1f02\\u03bd \\u03bc\\u03cc\\u03bd\\u03bf\\u03c2, \\u2018\\u1f67 \\u03bb\\u1ff6\\u03c3\\u03c4\\u03b5\\u2019, \\u03c3\\u03cd. \\u03c0\\u03bf\\u1fe6 \\u03b3\\u1f70\\u03c1 \\u03c4\\u1f78 \\u03b2\\u03ad\\u03b2\\u03b1\\u03b9\\u03bf\\u03bd \\u03c4\\u1ff6\\u03bd \\u1f20\\u03b8\\u1ff6\\u03bd \\u1f10\\u03ba\\u03b5\\u03af\\u03bd\\u03c9\\u03bd \\u03ba\\u03b1\\u1f76 \\u03c4\\u1fc6\\u03c2 \\u03c0\\u03c1\\u1f78\\u03c2 \\u1f21\\u03bc\\u1fb6\\u03c2 \\u03b1\\u1f30\\u03b4\\u03bf\\u1fe6\\u03c2 \\u03ba\\u03b1\\u1f76 \\u03c4\\u1ff6\\u03bd \\u03c0\\u03bb\\u03bf\\u03c5\\u03c3\\u03af\\u03c9\\u03bd \\u1f10\\u03ba\\u03b5\\u03af\\u03bd\\u03c9\\u03bd \\u1f51\\u03c0\\u03bf\\u03c3\\u03c7\\u03ad\\u03c3\\u03b5\\u03c9\\u03bd, \\u1f03\\u03c2 \\u1f51\\u03c0\\u1f72\\u03c1 \\u03c4\\u03bf\\u1fe6 \\u03b1\\u1f30\\u03b5\\u1f76 \\u03bc\\u03b5\\u03bc\\u03bd\\u1fc6\\u03c3\\u03b8\\u03b1\\u03b9 \\u03ba\\u03b1\\u1f76 \\u03b3\\u03c1\\u03ac\\u03c6\\u03b5\\u03b9\\u03bd \\u1f21\\u03bc\\u1fd6\\u03bd \\u03c0\\u03c1\\u03bf\\u1f54\\u03c4\\u03b5\\u03b9\\u03bd\\u03b1\\u03c2; \\u1f00\\u03bb\\u03bb\\u1f70 \\u03c3\\u1f7a \\u03bc\\u1f72\\u03bd \\u03bf\\u1f37\\u03bf\\u03c2 \\u1f02\\u03bd \\u1f10\\u03b8\\u03ad\\u03bb\\u03bf\\u03b9\\u03c2, \\u1f14\\u03c3\\u03bf\\u00b7 \\u1f21\\u03bc\\u03b5\\u1fd6\\u03c2 \\u03b4\\u2019 \\u1f35\\u03bd\\u2019 \\u03b5\\u1f30\\u03b4\\u03b5\\u03af\\u03b7\\u03c2 \\u1f61\\u03c2 \\u1f00\\u03bc\\u03b5\\u03c4\\u03b1\\u03b2\\u03bb\\u03ae\\u03c4\\u03c9\\u03c2 \\u1f14\\u03c7\\u03bf\\u03bc\\u03b5\\u03bd, \\u1f10\\u03bb\\u03b8\\u03ad, \\u03c4\\u1fc6\\u03c2 \\u1f21\\u03bc\\u03b5\\u03c4\\u03ad\\u03c1\\u03b1\\u03c2 \\u1f51\\u03c0\\u03bf\\u03c3\\u03c7\\u03ad\\u03c3\\u03b5\\u03c9\\u03c2, \\u03b5\\u1f30 \\u03b2\\u03bf\\u03cd\\u03bb\\u03b5\\u03b9, \\u03bc\\u03b5\\u03b8\\u03ad\\u03be\\u03c9\\u03bd. \\u03b5\\u1f30\\u03c3\\u1f76 \\u03b3\\u1f70\\u03c1 \\u03bf\\u1f33 \\u03bd\\u1fe6\\u03bd \\u1f00\\u03ba\\u03c1\\u03bf\\u1ff6\\u03bd\\u03c4\\u03b1\\u03b9 \\u03c4\\u1fc6\\u03c2 \\u03a6\\u03c5\\u03c3\\u03b9\\u03ba\\u1fc6\\u03c2 \\u03c0\\u03b1\\u03c1\\u2019 \\u1f21\\u03bc\\u1ff6\\u03bd \\u1f08\\u03ba\\u03c1\\u03bf\\u03ac\\u03c3\\u03b5\\u03c9\\u03c2 \\u03c4\\u1fc6\\u03c2 \\u1f08\\u03c1\\u03b9\\u03c3\\u03c4\\u03bf\\u03c4\\u03ad\\u03bb\\u03bf\\u03c5\\u03c2 \\u03ba\\u03b1\\u1f76 \\u03c0\\u03c1\\u03cc\\u03c2 \\u03b3\\u03b5 \\u03b4\\u1f74 \\u03c4\\u1fc6\\u03c2 \\u1f45\\u03bb\\u03b7\\u03c2 \\u1f00\\u03bd\\u03b5\\u03bb\\u03bb\\u03b9\\u03c0\\u1ff6\\u03c2 \\u03bb\\u03bf\\u03b3\\u03b9\\u03ba\\u1fc6\\u03c2 \\u03c0\\u03c1\\u03b1\\u03b3\\u03bc\\u03b1\\u03c4\\u03b5\\u03af\\u03b1\\u03c2 \\u1f10\\u03ba\\u03b5\\u03af\\u03bd\\u03bf\\u03c5\\u00b7 \\u03bc\\u03b7\\u03b4\\u1f72 \\u03b3\\u1f70\\u03c1 \\u1f02\\u03bd \\u03b5\\u1f34\\u03b7 \\u03c8\\u03b5\\u03cd\\u03b4\\u03b5\\u03c3\\u03b8\\u03b1\\u03b9 \\u03c4\\u1f70\\u03c2 \\u1f10\\u03bc\\u1f70\\u03c2 \\u1f51\\u03c0\\u03bf\\u03c3\\u03c7\\u03ad\\u03c3\\u03b5\\u03b9\\u03c2 \\u1f11\\u03ba\\u03cc\\u03bd\\u03c4\\u03bf\\u03c2.\",\n          \"\\u03a3\\u1f7a \\u03bc\\u03ad\\u03bd, \\u1f04\\u03c1\\u03b9\\u03c3\\u03c4\\u03b5 \\u03c3\\u03c4\\u03c1\\u03b1\\u03c4\\u03b7\\u03b3\\u1ff6\\u03bd, \\u03b5\\u1f50\\u03b4\\u03bf\\u03ba\\u03af\\u03bc\\u03b5\\u03b9 \\u03c0\\u03c1\\u03ac\\u03c4\\u03c4\\u03c9\\u03bd \\u03b5\\u1f56 \\u03ba\\u03b1\\u1f76 \\u1f61\\u03c2 \\u03b5\\u1f54\\u03be\\u03b1\\u03b9\\u03c4\\u2019 \\u1f02\\u03bd \\u1f51\\u03c0\\u1f72\\u03c1 \\u1f11\\u03b1\\u03c5\\u03c4\\u03bf\\u1fe6 \\u03c0\\u03ac\\u03bd\\u03c4\\u03c9\\u03bd \\u1f15\\u03ba\\u03b1\\u03c3\\u03c4\\u03bf\\u03c2, \\u1f04\\u03bb\\u03bb\\u03b1\\u03b9\\u03c2 \\u1f10\\u03be \\u1f04\\u03bb\\u03bb\\u03c9\\u03bd \\u1f00\\u03b3\\u03b1\\u03b8\\u03b1\\u1fd6\\u03c2 \\u1f00\\u03b5\\u1f76 \\u03c0\\u03b1\\u03c1\\u03b1- \\u03b2\\u03b1\\u03bb\\u03bb\\u03cc\\u03bc\\u03b5\\u03bd\\u03bf\\u03c2 \\u03c0\\u03c1\\u03ac\\u03be\\u03b5\\u03c3\\u03b9 \\u03ba\\u03b1\\u1f76 \\u03c0\\u03b1\\u03bd\\u03c4\\u03b1\\u03c7\\u03cc\\u03b8\\u03b5\\u03bd \\u03c4\\u1f78 \\u03ba\\u03c1\\u03ac\\u03c4\\u03bf\\u03c2 \\u03ba\\u03b1\\u03c1\\u03c0\\u03bf\\u03cd\\u03bc\\u03b5\\u03bd\\u03bf\\u03c2\\u00b7 \\u1f21\\u03bc\\u03b5\\u1fd6\\u03c2 \\u03b4\\u1f72 \\u03c4\\u1ff7 \\u03bd\\u1ff7 \\u03ba\\u03b1\\u1f76 \\u03c4\\u1fc7 \\u03b3\\u03bb\\u03ce\\u03c4\\u03c4\\u1fc3 \\u03bb\\u03b1\\u03bc\\u03c0\\u03c1\\u1f70\\u03bd \\u03c0\\u03b1\\u03c1\\u1f70 \\u03c3\\u03bf\\u1fe6 \\u03c0\\u03bf\\u03c1\\u03b9\\u03b6\\u03cc\\u03bc\\u03b5\\u03bd\\u03bf\\u03b9 \\u03c4\\u1f74\\u03bd \\u1f10\\u03bb\\u03b5\\u03c5\\u03b8\\u03b5\\u03c1\\u03af\\u03b1\\u03bd, \\u03c0\\u03b1\\u03c1\\u1f70 \\u03c4\\u1f70\\u03c2 \\u03c4\\u1ff6\\u03bd \\u03c3\\u1ff6\\u03bd \\u1f10\\u03b3\\u03ba\\u03c9\\u03bc\\u03af\\u03c9\\u03bd \\u03b8\\u03b1\\u03bb\\u03ac\\u03c3\\u03c3\\u03b1\\u03c2 \\u03b5\\u1f50\\u03c0\\u03b5\\u03c4\\u1ff6\\u03c2 \\u03c0\\u03b5\\u03bb\\u03b1\\u03b3\\u03af\\u03b6\\u03b5\\u03b9\\u03bd \\u03bf\\u1f50\\u03ba \\u1f04\\u03bd \\u03c0\\u03bf\\u03c4\\u2019 \\u1f40\\u03ba\\u03bd\\u03ae\\u03c3\\u03b1\\u03b9\\u03bc\\u03b5\\u03bd, \\u1f00\\u03bd\\u03b8\\u03bf\\u03bb\\u03bf\\u03b3\\u03bf\\u1fe6\\u03bd\\u03c4\\u03b5\\u03c2 \\u03c4\\u1f70 \\u03ba\\u03c1\\u03ac\\u03c4\\u03b9\\u03c3\\u03c4\\u03b1 \\u03ba\\u03b1\\u1f76 \\u03c3\\u03c4\\u03ad\\u03c6\\u03b1\\u03bd\\u03cc\\u03bd \\u03c3\\u03bf\\u03b9 \\u03b4\\u03b7\\u03bc\\u03b9\\u03bf\\u03c5\\u03c1\\u03b3\\u03bf\\u1fe6\\u03bd\\u03c4\\u03b5\\u03c2 \\u03bb\\u03bf\\u03b3\\u03b9\\u03ba\\u1f78\\u03bd \\u03ba\\u03b1\\u1f76 \\u1f00\\u03ba\\u03ae\\u03c1\\u03b1\\u03c4\\u03bf\\u0