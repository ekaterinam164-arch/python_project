          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Кластеров: 5\n",
            "Выбросов: 62\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "Выбросов многовато, можно сделать и меньше, но тогда количество кластеров тоже уменьшится. Посмотрим, что есть в этих кластерах."
      ],
      "metadata": {
        "id": "XmOf7hmDQ6Bd"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "for cluster_id in sorted(set(labels)):\n",
        "    indices = [i for i, l in enumerate(labels) if l == cluster_id]\n",
        "    label = \"Выбросы\" if cluster_id == -1 else f\"Кластер {cluster_id}\"\n",
        "    print(f\"{label}: {indices}\")"
